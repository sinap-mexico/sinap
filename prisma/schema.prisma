// Sinap OS — Multi-tenant SaaS Platform for Health Clinics
// Schema v1.0 — Fase 1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  
  // Sinap-specific fields
  role          String    @default("owner") // "owner" | "doctor" | "staff"
  clinicId      String?
  phone         String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  clinic        Clinic?   @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([clinicId])
}

// ─── TENANT ──────────────────────────────────────────────

model Clinic {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  mode          String   @default("solo") // "solo" | "clinic"
  rfc           String?  // RFC para facturación México
  regimenFiscal String?  // Régimen fiscal SAT
  email         String
  phone         String?
  address       String?
  city          String?
  state         String?
  country       String   @default("MX")

  // Meta Business API config
  wabaId         String?  // WhatsApp Business Account ID
  phoneNumberId  String?  // Meta Phone Number ID
  metaAccessToken String? // Encrypted access token
  igBusinessId   String?  // Instagram Business Account ID
  fbPageId       String?  // Facebook Page ID

  // Facturama config
  facturamaUserId   String?
  facturamaToken    String?
  facturamaSandbox  Boolean @default(true)
  defaultIvaRate    Float   @default(0) // Tasa IVA por defecto: 0 = exento (salud), 0.16 = 16%

  // Plan & billing
  plan           String   @default("starter") // "starter" | "pro" | "premium"
  monthlyConvLimit Int    @default(200)
  maxDoctors     Int      @default(1)

  // Trial & subscription
  trialStart     DateTime? // When the 7-day trial started
  trialEnd       DateTime? // When the 7-day trial expires
  isActive       Boolean  @default(true) // False when trial expired and not subscribed

  // Branding
  logoUrl        String?
  primaryColor   String   @default("#1D9E75")
  personaName    String?  // Nombre del agente IA (ej. "Asistente del Dr. Martínez")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  doctors          Doctor[]
  patients         Patient[]
  appointments     Appointment[]
  invoices         Invoice[]
  conversations    Conversation[]
  messages         Message[]
  featureFlags     FeatureFlag[]
  events           EventBus[]
  staff            Staff[]
  services         Service[]
  soapNotes        SoapNote[]
  users            User[]
  followUps        FollowUp[]
  metaConnections  MetaConnection[]
  campaigns        Campaign[]
  expenses         Expense[]
  inventoryItems   InventoryItem[]
  notifications    Notification[]
  patientDocuments PatientDocument[]
}

model Doctor {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  email       String?
  phone       String?
  specialty   String?
  license     String?  // Cédula profesional
  color       String   @default("#1D9E75") // Color en agenda
  isActive    Boolean  @default(true)

  // Agenda config
  workDays    String   @default("1,2,3,4,5") // Lun-Vie
  workStart   String   @default("09:00")
  workEnd     String   @default("18:00")
  slotMinutes Int      @default(30)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  services    ServiceDoctor[]
  soapNotes   SoapNote[]

  @@index([clinicId])
}

model Staff {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  email     String?
  phone     String?
  role      String   @default("receptionist") // "receptionist" | "assistant" | "admin" | "manager"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model Service {
  id          String   @id @default(cuid())
  clinicId    String
  name        String   // "Consulta general", "Limpieza dental", etc.
  description String?
  duration    Int      @default(30) // minutos
  price       Float    @default(0)
  ivaRate     Float    @default(0) // Tasa de IVA: 0 = exento (salud), 0.16 = 16%, etc.
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctors     ServiceDoctor[]
  appointments Appointment[]

  @@index([clinicId])
}

model ServiceDoctor {
  id        String   @id @default(cuid())
  serviceId String
  doctorId  String

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([serviceId, doctorId])
}

// ─── PATIENTS ────────────────────────────────────────────

model Patient {
  id            String   @id @default(cuid())
  clinicId      String
  firstName     String
  lastName      String
  fullName      String
  phone         String?
  email         String?
  birthDate     DateTime?
  gender        String?  // "M" | "F" | "other"
  rfc           String?  // Para facturación
  address       String?

  // CRM fields
  source        String?  // "whatsapp" | "instagram" | "facebook" | "referral" | "walk_in"
  firstContactDate DateTime?
  lastVisitDate DateTime?
  totalVisits   Int      @default(0)
  totalSpent    Float    @default(0)
  ltv           Float    @default(0)
  segment       String   @default("new") // "new" | "active" | "inactive" | "churned" | "vip"
  sentiment     String   @default("neutral") // "positive" | "neutral" | "negative"

  // Preferences
  preferredChannel String? @default("whatsapp")
  preferredTime   String? // "morning" | "afternoon" | "evening"
  doNotContact    Boolean @default(false)

  // Clinical
  allergies      String?
  medicalHistory String? // JSON string con antecedentes
  notes          String?

  // Emergency contact
  emergencyContactName     String?   // Nombre del contacto de emergencia
  emergencyContactPhone    String?   // Teléfono del contacto de emergencia
  emergencyContactRelation String?   // Relación (esposo/a, padre, madre, hijo/a, amigo, otro)

  // Insurance
  insuranceProvider     String?   // Aseguradora
  insurancePolicyNumber String?   // Número de póliza

  // Soft delete
  isActive       Boolean  @default(true)  // Soft delete support

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  invoices      Invoice[]
  conversations Conversation[]
  soapNotes     SoapNote[]
  followUps     FollowUp[]
  documents     PatientDocument[]

  @@index([clinicId])
  @@index([clinicId, phone])
  @@index([clinicId, segment])
  @@index([clinicId, isActive])
}

// ─── PATIENT DOCUMENTS ────────────────────────────────────

model PatientDocument {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String

  // Document info
  name        String   // Display name (e.g. "Radiografía torácica")
  type        String   @default("file") // "file" | "link"
  category    String   @default("study") // "study" | "xray" | "lab" | "prescription" | "insurance" | "other"

  // File storage
  fileUrl     String?  // URL del archivo subido (Supabase Storage / external)
  fileName    String?  // Original filename
  fileType    String?  // MIME type (application/pdf, image/jpeg, etc.)
  fileSize    Int?     // Size in bytes

  // Link storage
  linkUrl     String?  // URL para estudios en línea u otros hipervínculos

  // Metadata
  description String?  // Descripción o notas sobre el documento
  date        DateTime? // Fecha del documento/estudio (puede ser distinta a createdAt)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId])
  @@index([clinicId, category])
  @@map("patient_documents")
}

// ─── APPOINTMENTS ────────────────────────────────────────

model Appointment {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String
  doctorId    String
  serviceId   String?

  date        DateTime
  startTime   String   // "10:00"
  endTime     String   // "10:30"
  status      String   @default("scheduled") // "scheduled" | "confirmed" | "in_progress" | "completed" | "cancelled" | "no_show"
  channel     String   @default("whatsapp")  // Canal por el que se agendó

  // Pre-consulta
  preConsultCompleted Boolean @default(false)
  preConsultData String? // JSON con respuestas de pre-consulta

  notes       String?
  cancelReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  invoice     Invoice?
  soapNote    SoapNote?

  @@index([clinicId, date])
  @@index([clinicId, status])
  @@index([doctorId, date])
  @@index([patientId])
}

// ─── CLINICAL ────────────────────────────────────────────

model SoapNote {
  id             String   @id @default(cuid())
  clinicId       String
  patientId      String
  appointmentId  String?  @unique
  doctorId       String

  subjective     String?  // S - Síntomas del paciente
  objective      String?  // O - Hallazgos objetivos
  assessment     String?  // A - Diagnóstico/Diferenciales
  plan           String?  // P - Plan de tratamiento

  // IA metadata
  aiGenerated    Boolean  @default(false)
  aiSuggested    Boolean  @default(false) // True si fue ASSIST mode
  doctorApproved Boolean  @default(false)
  doctorSignedAt DateTime?

  // Additional clinical data
  vitals         String?  // JSON: {bp: "120/80", hr: 72, temp: 36.5, weight: 70}
  diagnosis      String?
  prescriptions  String?  // JSON array de recetas
  attachments    String?  // JSON array de URLs

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic         Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor         Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId])
  @@index([clinicId, doctorId])
}

// ─── BILLING ─────────────────────────────────────────────

model Invoice {
  id              String   @id @default(cuid())
  clinicId        String
  patientId       String
  appointmentId   String?  @unique

  // CFDI 4.0 fields
  cfdiUuid        String?  // UUID del CFDI timbrado por SAT
  cfdiVersion     String   @default("4.0")
  serie           String?  // Serie de la factura
  folio           String?  // Folio consecutivo
  fechaTimbrado   DateTime?

  // Amounts
  subtotal        Float    @default(0)
  iva             Float    @default(0)
  ivaRate         Float    @default(0) // Tasa de IVA usada: 0 = exento, 0.16 = 16%
  total           Float    @default(0)
  currency        String   @default("MXN")

  // CFDI details
  formaPago       String   @default("01") // SAT catalog
  metodoPago      String   @default("PUE") // PUE o PPD
  tipoComprobante String   @default("I") // I=Ingreso
  usoCFDI         String   @default("G01") // SAT catalog
  concepto        String?  // Descripción del servicio

  // Status
  status          String   @default("pending") // "pending" | "timbrada" | "cancelled" | "error"
  paymentStatus   String   @default("unpaid") // "unpaid" | "paid" | "partial"
  paidAt          DateTime?

  // Facturama response
  facturamaId     String?  // ID en Facturama
  pdfUrl          String?  // URL del PDF
  xmlUrl          String?  // URL del XML

  errorMessage    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic          Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  payments        Payment[]

  @@index([clinicId, status])
  @@index([clinicId, createdAt])
  @@index([patientId])
}

// ─── PAYMENTS ────────────────────────────────────────────

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float    // amount of this specific payment
  formaPago   String   // "01 Efectivo", "02 Transferencia", "03 Tarjeta", etc.
  reference   String?  // optional reference number (transfer #, last 4 digits, etc.)
  notes       String?  // optional notes
  createdBy   String?  // user who recorded the payment
  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@map("payments")
}

// ─── CONVERSATIONS & MESSAGES ────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String?

  channel     String   @default("whatsapp") // "whatsapp" | "instagram" | "messenger"
  status      String   @default("active")   // "active" | "closed" | "handed_off"

  // Agent routing
  currentAgent String? // "reception" | "clinical" | "billing" | "marketing"
  routedToHuman Boolean @default(false)
  humanAssignee String? // staff ID

  // Context
  intent      String?  // "schedule" | "reschedule" | "cancel" | "inquiry" | "complaint" | "billing"
  sentiment   String   @default("neutral")
  isMock      Boolean  @default(false) // True si es simulación

  lastMessageAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  messages    Message[]

  @@index([clinicId, status])
  @@index([clinicId, channel])
  @@index([clinicId, lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  clinicId       String
  conversationId String

  direction      String   // "inbound" | "outbound"
  channel        String   @default("whatsapp")
  senderType     String   // "patient" | "agent" | "doctor" | "system"
  senderId       String?  // ID del agente o doctor

  content        String
  messageType    String   @default("text") // "text" | "image" | "document" | "template" | "interactive"
  mediaUrl       String?

  // AI metadata
  agentName      String?  // "reception" | "clinical" | "billing"
  aiGenerated    Boolean  @default(false)
  confidence     Float?   // 0-1 confidence del agente

  isMock         Boolean  @default(false)

  // WhatsApp tracking
  wamid          String?   // WhatsApp message ID for status tracking

  createdAt      DateTime @default(now())

  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([clinicId, createdAt])
}

// ─── FEATURE FLAGS ───────────────────────────────────────

model FeatureFlag {
  id        String   @id @default(cuid())
  clinicId  String
  module    String   // "desk" | "flow" | "bill" | "grow" | "sight" | "hub"
  feature   String   // "autoSchedule" | "soapNote" | "autoCFDI" etc.
  state     String   @default("assist") // "on" | "assist" | "off"
  config    String?  // JSON con config adicional (thresholds, subfields, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, module, feature])
  @@index([clinicId, module])
}

// ─── EVENT BUS ───────────────────────────────────────────

model EventBus {
  id          String   @id @default(cuid())
  clinicId    String
  eventType   String   // "cita_agendada" | "cita_completada" | "factura_generada" etc.
  sourceAgent String   // "desk" | "flow" | "bill" | "grow" | "sight" | "hub" | "system"
  targetAgent String?  // Agent que debe procesar, null = broadcast
  payload     String   // JSON con datos del evento
  status      String   @default("pending") // "pending" | "processed" | "failed"
  processedAt DateTime?

  createdAt   DateTime @default(now())

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, eventType])
  @@index([clinicId, status])
  @@index([createdAt])
}

// ─── FOLLOW-UPS ─────────────────────────────────────────

model FollowUp {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String
  type        String   // "call" | "message" | "appointment" | "reminder" | "note"
  status      String   @default("pending") // "pending" | "completed" | "cancelled" | "snoozed"
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdBy   String?  // User or Staff ID

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@index([clinicId, dueDate])
  @@index([patientId])
}

// ─── META CONNECTIONS ────────────────────────────────────

model MetaConnection {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Channel type
  channel         String   // "whatsapp" | "instagram" | "messenger"

  // Meta credentials
  businessId      String?  // WABA ID (whatsapp) or IG Business ID (instagram) or Page ID (messenger)
  phoneNumberId   String?  // Only for WhatsApp
  pageId          String?  // Facebook Page ID (for instagram DMs and messenger)
  accessToken     String   // Access token for this channel
  tokenExpiresAt  DateTime? // Null for permanent tokens

  // Status
  status          String   @default("active") // "active" | "disconnected" | "expired" | "pending"
  businessName    String?  // Cached business/page name from Meta

  // Embedded Signup (future)
  oauthCode       String?  // Authorization code from Embedded Signup
  scopes          String?  // Granted scopes as comma-separated string

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clinicId, channel])  // One connection per channel per clinic
  @@index([clinicId])
  @@index([status])
  @@map("meta_connections")
}

// ─── CAMPAIGNS ──────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  type        String   @default("whatsapp") // "whatsapp" | "email" | "sms" | "both"
  campaignType String  @default("promocion") // "reactivacion" | "retencion" | "vip" | "promocion" | "recordatorio"
  channel     String   @default("whatsapp") // "whatsapp" | "email" | "both"
  status      String   @default("draft") // "draft" | "scheduled" | "sending" | "active" | "completed" | "paused"
  segment     String   @default("all") // Target segment: "all" | "new" | "active" | "inactive" | "churned" | "vip"
  subject     String?  // Email subject (for email campaigns)
  content     String   // Message body
  scheduledAt DateTime?
  sentAt      DateTime?
  recipientCount Int   @default(0)
  sentCount   Int      @default(0)
  deliveredCount Int   @default(0)
  openedCount Int      @default(0)
  respondedCount Int  @default(0)
  openRate    Float    @default(0)
  clickRate   Float    @default(0)
  responseRate Float   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@index([clinicId, campaignType])
  @@map("campaigns")
}

// ─── EXPENSES ────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  clinicId    String
  category    String   // "rent" | "supplies" | "salaries" | "equipment" | "services" | "marketing" | "utilities" | "other"
  description String
  amount      Float
  date        DateTime
  isRecurring Boolean  @default(false)
  recurrence  String?  // "monthly" | "weekly" | "yearly"
  vendor      String?
  notes       String?
  receiptUrl  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, date])
  @@index([clinicId, category])
  @@map("expenses")
}

// ─── INVENTORY ────────────────────────────────────────────

model InventoryItem {
  id            String    @id @default(cuid())
  clinicId      String
  name          String
  category      String    // "medication" | "supply" | "equipment" | "instrument" | "other"
  quantity      Int       @default(0)
  minQuantity   Int       @default(5)
  unit          String    @default("pieza") // "pieza" | "caja" | "frasco" | "ml" | "mg"
  costPerUnit   Float     @default(0)
  supplier      String?
  expiryDate    DateTime?
  location      String?
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clinic        Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, category])
  @@index([clinicId, isActive])
  @@map("inventory_items")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  clinicId    String
  userId      String?  // Null = all users in clinic, specific user = targeted
  type        String   // "appointment" | "payment" | "invoice" | "system" | "campaign" | "message"
  title       String
  message     String
  icon        String?  // Icon name from lucide-react
  actionUrl   String?  // URL to navigate when clicked (e.g. /dashboard?module=bill)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, userId, isRead])
  @@index([clinicId, createdAt])
  @@map("notifications")
}

// ─── META WEBHOOK EVENTS (Audit & Idempotency) ──────────

model MetaWebhookEvent {
  id                String   @id @default(cuid())
  providerEventId   String?  @unique // Stable event ID from Meta for dedup
  clinicId          String?
  channel           String?  // "whatsapp" | "instagram" | "messenger"
  payload           String   // Raw JSON payload
  signatureValid    Boolean  @default(false)
  processingStatus  String   @default("pending") // "pending" | "processed" | "failed"
  errorMessage      String?
  receivedAt        DateTime @default(now())
  processedAt       DateTime?

  @@index([providerEventId])
  @@index([clinicId])
  @@index([processingStatus])
  @@index([receivedAt])
  @@map("meta_webhook_events")
}
